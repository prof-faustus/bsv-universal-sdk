{
  "name": "@bsv-universal/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node --experimental-strip-types src/main.ts",
    "bundle": "esbuild src/main.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/desktop.cjs",
    "build:exe": "node scripts/build-exe.mjs",
    "test": "node --experimental-strip-types --test \"test/**/*.test.ts\""
  },
  "dependencies": {
    "@bsv-universal/practice": "workspace:*",
    "@bsv-universal/engine": "workspace:*",
    "@bsv-universal/crypto": "workspace:*",
    "@bsv-universal/protocol-types": "workspace:*"
  },
  "devDependencies": {
    "esbuild": "0.24.0",
    "postject": "1.0.0-alpha.6"
  }
}
